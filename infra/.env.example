# VitalLens AI - Environment Variables Template
# Copy this file to .env and fill in your actual keys.

# AI Configuration
# Get your key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# WHOOP API Configuration
# Get your credentials at https://developer.whoop.com/
WHOOP_CLIENT_ID=your_whoop_client_id_here
WHOOP_CLIENT_SECRET=your_whoop_client_secret_here
WHOOP_REDIRECT_URI=http://localhost:8080/api/v1/recovery/oauth2/callback/whoop

# Database Configuration
DATABASE_URL=postgresql://vitallens:password@postgres:5432/vitallens_db
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/vitallens_db
SPRING_DATASOURCE_USERNAME=vitallens
SPRING_DATASOURCE_PASSWORD=password

# Messaging
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
